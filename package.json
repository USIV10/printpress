{
  "name": "printpress",
  "version": "1.0.0",
  "description": "Printing Press Sales & Profit Management System",
  "main": "electron/main.js",
"scripts": {
  "build:frontend": "vite build",
  "build": "rm -rf dist-electron && npm run build:frontend && electron-builder"
},
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "dayjs": "^1.11.10",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.8.2",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.13",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9",
    "vite": "^5.1.4",
    "wait-on": "^7.2.0"
  },
"build": {
  "appId": "com.printpress.app",
  "productName": "PrintPress",
  "asar": true,
  "files": [
    "dist/**/*",
    "main.js",
    "preload.js",
    "package.json"
  ],
  "extraResources": [],
  "win": {
    "target": "nsis"
  }
}
}
